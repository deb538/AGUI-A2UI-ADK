4. Frontend Integration: Registering Components
To render this securely in React via CopilotKit's a2ui-renderer engine, you explicitly define schemas using Zod. This forms a protective sandbox: the LLM can adjust layout parameters but cannot execute arbitrary Javascript injection scripts or break outside your predetermined styling primitives.

TypeScript
// lib/a2ui/definitions.ts
import { z } from 'zod';

export const clusterDefinitions = {
  StatusBadge: {
    description: 'Renders a colored system status capsule based on cluster state.',
    props: z.object({
      text: z.string(),
      variant: z.enum(['success', 'warning', 'error']).default('success'),
    }),
  },
  MetricCard: {
    description: 'Displays numerical application analytics with trend markers.',
    props: z.object({
      label: z.string(),
      value: z.string(),
      trend: z.enum(['up', 'down']).optional(),
    }),
  },
};
You then pair these types directly to your client application's UI kit components:

TypeScript
// lib/a2ui/renderers.tsx
import { createCatalog, type CatalogRenderers } from '@copilotkit/a2ui-renderer';
import { clusterDefinitions } from './definitions';
import { Badge } from '@/components/ui/badge';

const clusterRenderers: CatalogRenderers<typeof clusterDefinitions> = {
  StatusBadge: ({ props }) => {
    // Highly interactive or visually stylized component matching your design tokens
    return (
      <Badge variant={props.variant === 'error' ? 'destructive' : 'default'}>
        {props.text}
      </Badge>
    );
  },
  MetricCard: ({ props }) => (
    <div className="p-4 border rounded-xl backdrop-blur-md bg-white/10">
      <p className="text-xs text-muted-foreground">{props.label}</p>
      <h3 className="text-2xl font-bold">{props.value}</h3>
    </div>
  ),
};

export const customClusterCatalog = createCatalog(clusterDefinitions, clusterRenderers, {
  catalogId: 'cluster-management-system',
  includeBasicCatalog: true, // Inherits basic structural items like Rows and Columns
});
