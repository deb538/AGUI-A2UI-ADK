ADK_MODEL=openai/gpt-5-mini
ADK_USE_A2UI=true
## Optional: use AI Credits / OpenAI-compatible provider instead of Google
# Example: AI_CREDIT_API_KEY=sk-...
# When present, set ADK_MODEL to a provider-prefixed model like openai/gpt-5-mini
AI_CREDIT_API_KEY=
AI_CREDIT_BASE_URL=https://api.aicredits.in/v1
## LiteLLM / OpenAI compatibility
# LiteLLM expects `OPENAI_API_KEY` (and optionally `OPENAI_API_BASE`).
# If you set `AI_CREDIT_API_KEY` / `AI_CREDIT_BASE_URL`, the agent runtime
# will map them to `OPENAI_API_KEY` / `OPENAI_API_BASE` automatically.
